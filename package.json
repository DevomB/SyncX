{
  "name": "syncx",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "node scripts/verify-coconut.mjs && node scripts/copy-coconut.mjs",
    "build": "pnpm prebuild && turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:extension": "pnpm --filter @syncx/extension dev",
    "dev:web": "pnpm --filter @syncx/web dev",
    "deploy:cloud": "pnpm build && pnpm --filter @syncx/infra deploy -- --outputs-file outputs.json",
    "package:extension": "node scripts/package-extension.mjs"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
